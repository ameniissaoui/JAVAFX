<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<AnchorPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sante.controllers.reservationController">
    <HBox fx:id="navbar" alignment="CENTER" spacing="20"
          style="-fx-background-color: white; -fx-padding: 10;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- Logo aligné à gauche -->
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/sante.png" />
            </image>
        </ImageView>

        <!-- Espace pousseur -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Boutons centrés -->
        <Button style="-fx-text-fill: #3fbbc0; -fx-background-color: transparent;" text="Home" />
        <Button onAction="#reservationfront" style="-fx-text-fill: #3fbbc0; -fx-background-color: transparent;" text="Reservation" />
        <Button onAction="#eventfront" style="-fx-text-fill: #3fbbc0; -fx-background-color: transparent;" text="Event" />

        <!-- Espace pousseur (pour équilibrer à droite aussi) -->
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox alignment="CENTER" layoutX="360.0" layoutY="152.0" prefHeight="300.0" prefWidth="400.0" spacing="15">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3fbbc0;"  text="Modifier la Réservation" />

        <!-- Champ pour le nom -->
        <TextField fx:id="nameField" promptText="Nom de la réservation" style="-fx-pref-width: 300;" />

        <!-- Champ pour l'email -->
        <TextField fx:id="emailField" promptText="Email" style="-fx-pref-width: 300;" />

        <!-- Champ pour le nombre de personnes -->
        <TextField fx:id="peopleCountField" promptText="Nombre de personnes" style="-fx-pref-width: 300;" />

        <!-- Bouton pour enregistrer les modifications -->
        <Button fx:id="submitButton" onAction="#handleReservation" text="Enregistrer" style="-fx-background-color: #3fbbc0; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px; -fx-pref-width: 200px;" />

        <!-- Bouton pour annuler -->
        <Button fx:id="cancelButton" onAction="#cancelAction" text="Annuler" style="-fx-background-color: #3fbbc0; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px; -fx-pref-width: 200px;" />
    </VBox>

</AnchorPane>
