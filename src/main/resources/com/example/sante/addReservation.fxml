<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sante.controllers.reservationController"
            prefHeight="700.0" prefWidth="1200.0">

    <!-- Conteneur centré -->
    <HBox fx:id="navbar" alignment="CENTER" spacing="20"
          style="-fx-background-color: white; -fx-padding: 10;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- Logo aligné à gauche -->
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/sante.png" />
            </image>
        </ImageView>

        <!-- Espace pousseur -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Boutons centrés -->
        <Button style="-fx-text-fill:
#3fbbc0; -fx-background-color: transparent;" text="Home" />
        <Button onAction="#reservationfront" style="-fx-text-fill:
#3fbbc0; -fx-background-color: transparent;" text="Reservation" />
        <Button onAction="#eventfront" style="-fx-text-fill:
#3fbbc0; -fx-background-color: transparent;" text="Event" />

        <!-- Espace pousseur (pour équilibrer à droite aussi) -->
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox alignment="CENTER" layoutX="360.0" layoutY="152.0" prefHeight="400.0" prefWidth="480.0" spacing="15">

        <Label text="Réserver un Événement" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill:
#3fbbc0;"/>

        <!-- Event Info -->
        <VBox fx:id="eventInfoBox" alignment="CENTER" spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10px; -fx-background-radius: 5px;">
            <Label fx:id="eventTitleLabel" text="[Titre de l'événement]" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3fbbc0;"/>
            <Label fx:id="eventDateLabel" text="[Date]" style="-fx-font-size: 14px;"/>
            <Label fx:id="eventLocationLabel" text="[Lieu]" style="-fx-font-size: 14px;"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="15" alignment="CENTER">
            <!-- Nom Field -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Nom :" style="-fx-font-size: 14px;"/>
                <TextField fx:id="nameField" promptText="Entrez votre nom" style="-fx-font-size: 14px; -fx-padding: 5px; -fx-pref-width: 250px;" />
            </HBox>

            <!-- Email Field -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Email :" style="-fx-font-size: 14px;"/>
                <TextField fx:id="emailField" promptText="Entrez votre email" style="-fx-font-size: 14px; -fx-padding: 5px; -fx-pref-width: 250px;" />
            </HBox>

            <!-- Nombre de personnes -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Nombre de personnes :" style="-fx-font-size: 14px;"/>
                <TextField fx:id="peopleCountField" promptText="Entrez le nombre de personnes" style="-fx-font-size: 14px; -fx-padding: 5px; -fx-pref-width: 250px;" />
            </HBox>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="15" alignment="CENTER">
            <Button text="Annuler" fx:id="cancelButton" onAction="#cancelAction" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px; -fx-pref-width: 120px;"/>
            <Button text="Réserver" fx:id="submitButton" onAction="#handleReservation" style="-fx-background-color: #3fbbc0; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px; -fx-pref-width: 120px;"/>
        </HBox>
    </VBox>

</AnchorPane>