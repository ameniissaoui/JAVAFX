<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@styles/list.css,@styles/button.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sante.controllers.AddEvent">




   <!-- FORMULAIRE AJOUT ÉVÉNEMENT -->
   <center>
      <AnchorPane>
         <children>
            <!-- Titre du formulaire -->
            <Text fx:id="formTitle" layoutX="230.0" layoutY="20.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #0662d5;" text="Créer un Événement" />

            <!-- Conteneur pour les champs de texte et les boutons -->
            <VBox alignment="CENTER" layoutX="230.0" layoutY="60.0" spacing="15">
               <!-- Titre -->
               <TextField fx:id="titreField" promptText="Titre" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Date -->
               <DatePicker fx:id="dateEventField" promptText="Date" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Lieu -->
               <TextField fx:id="lieuField" promptText="Lieu" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Description -->
               <TextField fx:id="descriptionField" promptText="Description" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Nombre de places -->
               <TextField fx:id="nbPlaceField" promptText="Nombre de places" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Chemin de l'image -->
               <TextField fx:id="imageField" disable="true" promptText="Chemin de l'image" style="-fx-pref-width: 300px; -fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #ccc; -fx-border-radius: 5px;" />

               <!-- Bouton Choisir une image -->
               <Button fx:id="imageButton" onAction="#chooseImage" style="-fx-font-size: 14px; -fx-padding: 10px 20px; -fx-background-color: #0662d5; -fx-text-fill: white; -fx-background-radius: 5px;" text="Choisir une image" />

               <!-- Aperçu de l'image -->
               <ImageView fx:id="imageView" fitHeight="100.0" fitWidth="100.0" />

               <!-- Bouton Ajouter l'événement -->
               <Button fx:id="ajoutEvent" onAction="#ajoutevenement" style="-fx-font-size: 16px; -fx-padding: 10px 20px; -fx-background-color: #0662d5; -fx-text-fill: white; -fx-background-radius: 5px;" text="Ajouter Evenement" />
            </VBox>

         </children>
      </AnchorPane>
   </center>
</BorderPane>
